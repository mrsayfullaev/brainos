# Database
DATABASE_URL="postgresql://user:password@localhost:5432/brainos?schema=public"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# AI Providers
OPENAI_API_KEY="your_openai_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"

# GigaChat (OAuth credentials для автоматического получения токена)
# Получить: https://developers.sber.ru/portal/products/gigachat
# Нужны: Client ID и Client Secret
GIGACHAT_CLIENT_ID="your_client_id_here"
GIGACHAT_CLIENT_SECRET="your_client_secret_here"

CLAUDE_API_KEY="your_claude_api_key_here"

# Application
NODE_ENV="production"
LOG_LEVEL="info"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="20"

# Encryption (AES-256-GCM)
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Хранить в vault/secrets manager, не коммитить в репозиторий. Ротация — см. docs/ENCRYPTION.md
ENCRYPTION_KEY="your_32_byte_encryption_key_in_hex_64_chars"

# V4 Notion Integration (опционально)
# NOTION_CLIENT_ID="..."
# NOTION_CLIENT_SECRET="..."
# NOTION_REDIRECT_URI="https://your-domain/auth/notion/callback"  # или BASE_URL + /auth/notion/callback
# BASE_URL="https://your-domain"   # если не задан NOTION_REDIRECT_URI
# NOTION_WEBHOOK_PORT="3333"       # тот же порт, что и Stripe, или отдельный

# V4 Email Agent / Gmail OAuth (опционально)
# GMAIL_CLIENT_ID="..."
# GMAIL_CLIENT_SECRET="..."
# GMAIL_REDIRECT_URI="https://your-domain/auth/gmail/callback"
# GMAIL_WEBHOOK_PORT="3333"

# V4 Meeting Agent / Google Calendar OAuth (опционально)
# CALENDAR_CLIENT_ID="..."
# CALENDAR_CLIENT_SECRET="..."
# CALENDAR_REDIRECT_URI="https://your-domain/auth/calendar/callback"

# --- Дашборд и аналитика (если крутите apps/dashboard) ---
# DASHBOARD_ORIGIN — с какого origin разрешены CORS-запросы к /api/analytics/overview и др.
#   Локально: http://localhost:3001. В проде: https://your-dashboard-domain (или тот же BASE_URL, если дашборд на том же домене).
# DASHBOARD_ORIGIN="http://localhost:3001"
# ANALYTICS_API_KEY — обязателен для доступа к GET /api/analytics/overview и GET /api/user/export.
#   Без него эти эндпоинты всегда возвращают 403. Запросы должны содержать заголовок X-Api-Key: <этот_ключ>.
#   Сгенерировать: openssl rand -hex 32. Тот же ключ прописать в дашборде в apps/dashboard/.env.local:
#   NEXT_PUBLIC_ANALYTICS_API_KEY="<тот_же_ключ>"
ANALYTICS_API_KEY=""

# --- Redis (опционально) ---
# OAuth state (Notion/Gmail/Calendar), кэш LLM, очереди BullMQ. Без Redis — state в памяти, очереди отключены.
# Локально: redis://localhost:6379. С паролем: redis://:password@host:6379
REDIS_URL="redis://localhost:6379"

# --- Sentry (опционально) ---
# Мониторинг ошибок. Создайте проект на sentry.io → Settings → Client Keys (DSN) → скопируйте DSN.
# Формат: https://<key>@<org>.ingest.sentry.io/<project_id>
# SENTRY_DSN=""
