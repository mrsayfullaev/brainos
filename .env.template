# ─── ОБЯЗАТЕЛЬНЫЕ ───────────────────────────────────────────────────────────

# База данных (подставляется автоматически из DB_PASSWORD в docker-compose)
DB_PASSWORD=ЗАМЕНИТЕ_НА_ПАРОЛЬ

# Telegram
TELEGRAM_BOT_TOKEN=
BOT_USERNAME=

# Шифрование (64 hex-символа: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# OpenAI (обязателен — основной провайдер на UZ сервере)
OPENAI_API_KEY=

# GigaChat (обязателен для старта, но НЕ работает вне РФ → fallback на OpenAI)
# Если аккаунта нет — поставьте любые непустые значения, бот будет использовать OpenAI
GIGACHAT_CLIENT_ID=placeholder
GIGACHAT_CLIENT_SECRET=placeholder

# Публичный URL бота
BASE_URL=https://brainos.ai-khan.uz

# ─── РЕКОМЕНДУЕМЫЕ ──────────────────────────────────────────────────────────

# Analytics API (для дашборда)
# Сгенерировать: openssl rand -hex 32
ANALYTICS_API_KEY=

# CORS для дашборда
DASHBOARD_ORIGIN=https://brainos.ai-khan.uz

