# URL бэкенда BrainOS (health, analytics, auth). В проде — домен бота; локально — http://localhost:3333
NEXT_PUBLIC_API_URL="https://brainos.ai-khan.uz"
# Имя бота для Telegram Login Widget (без @)
NEXT_PUBLIC_TELEGRAM_BOT_NAME="YourBot"
# Тот же ключ, что ANALYTICS_API_KEY в .env бэкенда (обязателен для запросов к /api/analytics/overview)
NEXT_PUBLIC_ANALYTICS_API_KEY=""
