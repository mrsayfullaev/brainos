{
  "name": "brainos-multi-ai-bot",
  "version": "4.0.0",
  "description": "Multi-AI Telegram Bot with personalized responses",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:clear": "tsx scripts/clear-database.ts",
    "db:clear-force": "tsx scripts/clear-database.ts --force",
    "db:encrypt": "tsx scripts/encrypt-existing-data.ts",
    "test": "echo \"Tests will be added with modules\"",
    "test:openai": "tsx scripts/test-openai.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "telegram",
    "bot",
    "ai",
    "multi-ai",
    "grammy",
    "prisma",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "@grammyjs/ratelimiter": "^1.2.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.38.0",
    "axios": "^1.13.5",
    "bullmq": "^5.67.3",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.32.0",
    "ioredis": "^5.9.2",
    "mammoth": "^1.8.0",
    "node-cron": "^4.2.1",
    "openai": "^4.73.0",
    "pdf-parse": "^1.1.1",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
